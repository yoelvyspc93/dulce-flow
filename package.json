{
  "name": "dulce-flow",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "seed:web": "node ./scripts/start-with-seed.cjs --web",
    "seed:android": "node ./scripts/start-with-seed.cjs --android",
    "seed:ios": "node ./scripts/start-with-seed.cjs --ios",
    "web:export": "expo export -p web",
    "build:web:pwa": "yarn web:export && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html');fs.closeSync(fs.openSync('dist/.nojekyll','w'))\" && workbox generateSW workbox-config.cjs",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "date-fns": "^4.1.0",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "lucide-react-native": "^1.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.16",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/features/(.*)$": "<rootDir>/src/features/$1",
      "^@/shared/(.*)$": "<rootDir>/src/shared/$1",
      "^@/database/(.*)$": "<rootDir>/src/database/$1",
      "^@/theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@/store/(.*)$": "<rootDir>/src/store/$1"
    }
  },
  "private": true,
  "author": "yoelvyspc93",
  "license": "MIT"
}
