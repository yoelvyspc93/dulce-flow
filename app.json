{
  "expo": {
    "name": "dulce-flow",
    "slug": "dulce-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo.icon/Assets/grid.png",
    "scheme": "dulceflow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111F",
        "foregroundImage": "./assets/expo.icon/Assets/grid.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo.icon/Assets/grid.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/expo.icon/Assets/grid.png",
          "imageWidth": 76,
          "android": {
            "backgroundColor": "#07111F",
            "image": "./assets/expo.icon/Assets/grid.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "baseUrl": "/dulce-flow",
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
